{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/<owner>/SliceAI/blob/main/config.schema.json",
  "title": "SliceAI Configuration",
  "type": "object",
  "required": ["schemaVersion", "providers", "tools", "hotkeys", "triggers", "telemetry", "appBlocklist"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "appearance": {
      "type": "string",
      "enum": ["auto", "light", "dark"],
      "default": "auto",
      "description": "应用主题：跟随系统 / 浅色 / 深色"
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "baseURL", "apiKeyRef", "defaultModel"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "baseURL": { "type": "string", "format": "uri" },
          "apiKeyRef": { "type": "string", "pattern": "^keychain:" },
          "defaultModel": { "type": "string" },
          "thinking": {
            "type": ["object", "null"],
            "description": "Provider 的 thinking 切换能力。null=不支持；{\"byModel\":{}}=切 model id；{\"byParameter\":{\"enableBodyJSON\":\"...\",\"disableBodyJSON\":null|\"...\"}}=参数透传到 request body root。Swift Codable 自动序列化 ProviderThinkingCapability enum 后形如此结构。"
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "icon", "userPrompt", "providerId", "displayMode", "variables"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "systemPrompt": { "type": ["string", "null"] },
          "userPrompt": { "type": "string" },
          "providerId": { "type": "string" },
          "modelId": { "type": ["string", "null"] },
          "temperature": { "type": ["number", "null"] },
          "displayMode": { "type": "string", "enum": ["window", "bubble", "replace"] },
          "variables": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "thinkingModelId": {
            "type": ["string", "null"],
            "description": "仅当 Provider.thinking == byModel 时有意义；切换到 thinking 模式时改用此 model id"
          },
          "thinkingEnabled": {
            "type": "boolean",
            "default": false,
            "description": "用户上次切换的 thinking 偏好；ResultPanel toggle 后立即持久化"
          },
          "labelStyle": {
            "type": "string",
            "enum": ["icon", "name", "iconAndName"],
            "default": "icon",
            "description": "浮条上的显示样式：icon 仅图标 / name 仅名称 / iconAndName 图标+名称（名称按 4 个中文字或 1 个英文单词截断）"
          }
        }
      }
    },
    "hotkeys": {
      "type": "object",
      "required": ["toggleCommandPalette"],
      "properties": { "toggleCommandPalette": { "type": "string" } }
    },
    "triggers": {
      "type": "object",
      "required": ["floatingToolbarEnabled", "commandPaletteEnabled", "minimumSelectionLength", "triggerDelayMs"],
      "properties": {
        "floatingToolbarEnabled": { "type": "boolean" },
        "commandPaletteEnabled": { "type": "boolean" },
        "minimumSelectionLength": { "type": "integer", "minimum": 1 },
        "triggerDelayMs": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "floatingToolbarMaxTools": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20,
          "default": 6,
          "description": "悬浮工具栏最多直接展示的工具按钮数（不含溢出时额外追加的「⋯ 更多」按钮）"
        },
        "floatingToolbarSize": {
          "type": "string",
          "enum": ["compact", "regular"],
          "default": "compact",
          "description": "悬浮工具栏尺寸档位：compact 22pt / regular 30pt"
        },
        "floatingToolbarAutoDismissSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60,
          "default": 5,
          "description": "悬浮工具栏自动消失倒计时（秒）；0 表示永不自动消失，仅靠选中工具或点击外部关闭"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "appBlocklist": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
